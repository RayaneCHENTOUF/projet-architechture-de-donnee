      "format": "CSV",
      "update_frequency": "annual"
    },
    {
      "id": "hotels",
      "layer": "bronze",
      "file": "bronze/les_hotels_classes_en_ile-de-france.csv",
      "sensitivity": "public",
      "source": "Atout France / data.gouv.fr",
      "description": "Hôtels classés en Île-de-France avec catégorie et localisation",
      "domain": "tourisme",
      "format": "CSV",
      "update_frequency": "annual"
    }
  ]
}
