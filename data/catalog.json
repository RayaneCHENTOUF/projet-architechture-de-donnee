      "description": "Transactions immobilières à Paris (Demandes de Valeurs Foncières)",
      "domain": "immobilier",
      "format": "CSV",
      "update_frequency": "semi-annual",
      "notes": "Données officielles de l'État, anonymisées mais granulaires (adresse par adresse)"
    },
    {
      "id": "loyers",
      "layer": "bronze",
      "file": "bronze/loyers.csv",
      "sensitivity": "public",
      "source": "DRIHL / data.gouv.fr",
      "description": "Loyers de référence par zone géographique (encadrement des loyers Paris)",
      "domain": "immobilier",
      "format": "CSV",
      "update_frequency": "annual"
    },
    {
      "id": "hlm",
      "layer": "bronze",
      "file": "bronze/hlm.csv",
      "sensitivity": "public",
      "source": "Ville de Paris / data.paris.fr",
      "description": "Logements sociaux financés à Paris par programme et bailleur",
